{
  "name": "@yiluxiangbei/eslint-config-monorepo",
  "version": "2.0.1",
  "author": "yiluxiangbei <1097692918@qq.com> (https://github.com/luomor-web)",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint ./test --fix",
    "release": "npm release:check && npm release:version && npm release:publish",
    "release:check": "npm lint:fix",
    "release:version": "bumpp package.json packages/*/package.json --execute=\"npm changelog\" --all",
    "release:publish": "npm publish -r --access public",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@yiluxiangbei/eslint-config": "workspace:*",
    "bumpp": "^9.4.1",
    "conventional-changelog-cli": "^4.1.0",
    "eslint": "^9.1.1",
    "typescript": "^5.4.5"
  }
}
